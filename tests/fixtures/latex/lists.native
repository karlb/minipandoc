[ BulletList
    [ [ Plain [ Str "one" ] ]
    , [ Plain [ Str "two" ]
      , BulletList
          [ [ Plain [ Str "nested" , Space , Str "a" ] ]
          , [ Plain [ Str "nested" , Space , Str "b" ] ]
          ]
      ]
    , [ Plain [ Str "three" ] ]
    ]
, OrderedList
    ( 1 , Decimal , Period )
    [ [ Plain [ Str "first" ] ] , [ Plain [ Str "second" ] ] ]
, OrderedList
    ( 1 , LowerAlpha , OneParen )
    [ [ Plain [ Str "alpha" ] ] , [ Plain [ Str "beta" ] ] ]
, DefinitionList
    [ ( [ Str "term" ]
      , [ [ Plain [ Str "definition" ] ]
        , [ Plain [ Str "another" , Space , Str "def" ] ]
        ]
      )
    ]
]
