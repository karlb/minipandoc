[ Div
    ( "Hello" , [ "section" ] , [] )
    [ Header 1 ( "" , [] , [] ) [ Str "Hello" ]
    , Para
        [ Str "A"
        , Space
        , Str "paragraph"
        , Space
        , Str "with"
        , Space
        , Emph [ Str "emph" ]
        , Space
        , Str "and"
        , Space
        , Strong [ Str "strong" ]
        , Space
        , Str "and"
        , Space
        , Link
            ( "" , [] , [] ) [ Str "link" ] ( "https://x.org" , "" )
        , Space
        , Str "and"
        , Space
        , Code ( "" , [] , [] ) "code"
        , Str "."
        ]
    , BulletList
        [ [ Plain [ Str "item" , Space , Str "one" ] ]
        , [ Plain [ Str "item" , Space , Str "two" ] ]
        ]
    , OrderedList
        ( 1 , DefaultStyle , DefaultDelim )
        [ [ Plain [ Str "first" ] ] , [ Plain [ Str "second" ] ] ]
    ]
]
