[ BulletList
    [ [ Plain [ Str "one" ] ]
    , [ Plain [ Str "two" ]
      , BulletList [ [ Plain [ Str "nested" ] ] ]
      ]
    , [ Plain [ Str "three" ] ]
    ]
, OrderedList
    ( 1 , Decimal , Period )
    [ [ Plain [ Str "a" ] ] , [ Plain [ Str "b" ] ] ]
, DefinitionList
    [ ( [ Str "term" ]
      , [ [ Plain [ Str "definition" ] ]
        , [ Plain [ Str "another" , Space , Str "definition" ] ]
        ]
      )
    ]
]
